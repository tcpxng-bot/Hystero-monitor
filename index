  const remaining=Math.max(0,HARD_STOP-def);
  document.getElementById('hero-remaining-val').textContent=remaining.toLocaleString();
  document.getElementById('hero-remaining-val').style.color=lv.color;
  const pct=Math.min(100,Math.round((def/HARD_STOP)*100));
  document.getElementById('hero-gauge-fill').style.width=pct+'%';
  document.getElementById('hero-gauge-fill').style.background=lv.color;
  document.getElementById('hero-gauge-pct').textContent=pct+'%';
  const descChip=document.getElementById('hero-desc-chip');
  descChip.textContent = lv.key==='SAFE' ? '✓ อยู่ในเกณฑ์ปกติ' : lv.key==='WARNING' ? '⚠ เฝ้าระวัง — แจ้งแพทย์' : '⛔ เกิน Hard Stop — หยุดทันที';
  descChip.style.color=lv.color; descChip.style.borderColor=lv.color;

  const cp=document.getElementById('clinical-panel');
  cp.style.background=lv.tint; cp.style.borderColor=lv.color;
  document.getElementById('cp-title').textContent='CLINICAL RECOMMENDATION — '+lv.key;
  document.getElementById('cp-title').style.color=lv.color;
  document.getElementById('cp-list').innerHTML=CLINICAL[lv.key].map(t=>`<li style="color:var(--text)">${t}</li>`).join('');

  document.getElementById('s-intake').textContent=state.mediaUsed.toLocaleString();
  document.getElementById('s-output').textContent=state.outputCollected.toLocaleString();
  const prevCP=Math.floor(state.mediaUsed/2000)*2000, nextCP=Math.ceil((state.mediaUsed+1)/2000)*2000;
  document.getElementById('s-next').textContent='+'+(nextCP-state.mediaUsed).toLocaleString();
  const ppct=state.mediaUsed===0?0:((state.mediaUsed-prevCP)/2000)*100;
  document.getElementById('progress-bar').style.width=Math.min(ppct,100)+'%';
  document.getElementById('progress-label').textContent=`Progress to CP${state.checkpoints.length+1} (${state.mediaUsed.toLocaleString()}/${nextCP.toLocaleString()} mL)`;
  document.getElementById('progress-pct').textContent=Math.round(ppct)+'%';
  document.getElementById('cp-no').textContent=state.checkpoints.length+1;
  document.getElementById('cp-target-val').textContent=nextCP.toLocaleString();

  if(state.checkpoints.length>0){
    document.getElementById('trend-card').style.display='block';
    const maxDef=Math.max(HARD_STOP,...state.checkpoints.map(c=>Math.max(0,c.deficit)));
    document.getElementById('trend-graph').innerHTML=state.checkpoints.map(cp=>{
      const d=Math.max(0,cp.deficit); const h=Math.max(4,Math.round((d/maxDef)*56));
      const l=getLevel(d);
      return `<div style="flex:1;display:flex;flex-direction:column;align-items:center;gap:2px">
        <div style="font-size:7px;color:${l.color}">${d>=1000?(d/1000).toFixed(1)+'k':d}</div>
        <div style="width:100%;height:${h}px;background:${l.color};border-radius:3px 3px 0 0;min-width:8px"></div>
        <div style="font-size:7px;color:var(--text2)">${cp.no}</div></div>`;
    }).join('');
    document.getElementById('trend-last-label').textContent='CP'+state.checkpoints.length;
  }

  const rows=document.getElementById('cp-rows');
  rows.innerHTML='';
  if(state.checkpoints.length===0){
    rows.innerHTML='<div id="cp-empty-state" style="text-align:center; color:var(--text2); font-size:12px; padding:14px; background:var(--card); border:1px solid var(--border); border-radius:10px; margin-bottom:7px">ยังไม่มีการบันทึก Checkpoint — กดปุ่มด้านบนเพื่อเริ่มบันทึกครั้งแรก</div>';
  }
  [...state.checkpoints].reverse().forEach((cp,i)=>{
    const l=getLevel(Math.max(0,cp.deficit));
    const row=document.createElement('div');
    row.className='cp-row'+(i===0?' latest':'');
    row.innerHTML=`
      <div class="cp-num">${cp.no}<div style="font-size:6.5px; font-weight:600; opacity:.75; margin-top:1px">${cp.cumMedia>=1000?(cp.cumMedia/1000).toFixed(1)+'k':cp.cumMedia}</div></div>
