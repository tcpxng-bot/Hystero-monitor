<div style="text-align:center; font-size:9.5px; color:var(--text2); margin-top:8px; padding-bottom:10px">
  Hysteroscopy Fluid Monitor • NSS 1,000 mL/ขวด • Monitor ทุก 2,000 mL
</div>

<script>
let state = { started:false, startTime:null, mediaUsed:0, outputCollected:0, checkpoints:[], patient:{}, timerInterval:null };
let SCRIPT_URL = localStorage.getItem('hystero_script_url') || '';
let voiceMode = localStorage.getItem('hystero_voice') || 'th';
let prevAlertLevel = 'SAFE';
let tapMediaVal = 0, tapOutputVal = 0, isManualMode = false;
const HARD_STOP = 2500;

const LEVELS = [
  { max:1500,  key:'SAFE',    color:'var(--green)', tint:'var(--green-tint)', hex:'#2E7D32' },
  { max:2500,  key:'WARNING', color:'var(--amber)',  tint:'var(--amber-tint)', hex:'#ED8F03' },
  { max:99999, key:'DANGER',  color:'var(--red)',    tint:'var(--red-tint)',   hex:'#C62828' },
];
function getLevel(d){ return LEVELS.find(l=>d<l.max) || LEVELS[2]; }
function esc(v){
  return String(v ?? '').replace(/[&<>"']/g, ch => ({
    '&':'&amp;', '<':'&lt;', '>':'&gt;', '"':'&quot;', "'":'&#39;'
  }[ch]));
}
function readMlInput(id){
  const raw = document.getElementById(id).value;
  if(raw === '') return 0;
  const value = Number(raw);
  return Number.isInteger(value) && value >= 0 ? value : NaN;
}
function getStoredCases(){
  try{
    const cases = JSON.parse(localStorage.getItem('hystero_cases') || '[]');
    return Array.isArray(cases) ? cases : [];
  }catch(e){
    return [];
  }
}
function safeFilePart(v, fallback='case'){
  const cleaned = String(v || '').replace(/[\\/:*?"<>|]+/g, '_').trim();
  return cleaned || fallback;
}
function safeSheetName(v){
  return String(v || 'Unknown').replace(/[\[\]:*?/\\]+/g, '_').slice(0,31) || 'Unknown';
}

const CLINICAL = {
  SAFE: ['✓ ติดตามตามรอบปกติ (ทุก 2,000 mL)', '✓ บันทึก intake/output ทุก checkpoint', '✓ รักษาความถูกต้องของ fluid balance'],
  WARNING: ['⚠ แจ้งแพทย์ผู้ผ่าตัดทราบ', '⚠ ติดตามอย่างใกล้ชิด', '⚠ ประเมินอาการผู้ป่วยซ้ำ', '⚠ พิจารณาจำกัดเวลาทำหัตถการ', '⚠ เตรียมพร้อมหยุดหัตถการหากค่ายังเพิ่มขึ้น'],
  DANGER: ['⛔ หยุดทำหัตถการทันที', '⛔ แจ้งแพทย์ผู้ผ่าตัดทันที', '⛔ ประเมินอาการผู้ป่วยซ้ำ', '⛔ ติดตาม vital signs', '⛔ พิจารณาตรวจ electrolyte หากมีข้อบ่งชี้', '⛔ บันทึกการดำเนินการที่ทำ'],
};

const VOICE_MSG = {
  th:{ WARNING:'คำเตือน ฟลูอิด เดฟิซิต ถึงระดับเฝ้าระวังแล้ว กรุณาแจ้งแพทย์และติดตามอย่างใกล้ชิด',
       DANGER:'อันตราย ฟลูอิด เดฟิซิต เกินค่าที่กำหนดแล้ว ควรหยุดหัตถการทันที' },
  en:{ WARNING:'Warning. Fluid deficit has reached the caution level. Please notify the surgeon and continue close monitoring.',
       DANGER:'Critical alert. Fluid deficit exceeded the maximum safe limit. Stop procedure immediately.' },
};

window.onload = () => {
  document.getElementById('f-date').value = new Date().toISOString().slice(0,10);
  applyTheme(localStorage.getItem('hystero_theme') || 'light');
  renderHistory();
  setVoiceMode(voiceMode, true);
  positionStickyBar();
  window.addEventListener('resize', positionStickyBar);
};
function positionStickyBar(){
  const tb=document.getElementById('topbar');
  document.getElementById('sticky-deficit').style.top = tb.offsetHeight+'px';
}

function applyTheme(theme){
  const btn=document.getElementById('theme-toggle-btn');
  if(theme==='dark'){ document.body.classList.add('dark-theme'); if(btn) btn.textContent='☀️'; }
  else { document.body.classList.remove('dark-theme'); if(btn) btn.textContent='🌙'; }
  localStorage.setItem('hystero_theme', theme);
}
function toggleTheme(){ applyTheme(document.body.classList.contains('dark-theme') ? 'light' : 'dark'); }

function showTab(t){
  document.getElementById('tab-record').style.display = t==='record'?'block':'none';
  document.getElementById('tab-history').style.display = t==='history'?'block':'none';
  document.querySelectorAll('.tab').forEach((el,i)=>el.classList.toggle('active', i===(t==='record'?0:1)));
  if(t==='history') renderHistory();
}

function setVoiceMode(mode, silent){
  voiceMode = mode;
  localStorage.setItem('hystero_voice', mode);
  ['th','en','mute'].forEach(m=>{
    const row=document.getElementById('voice-row-'+m);
    const radio=document.getElementById('voice-'+m);
    if(row) row.classList.toggle('checked', m===mode);
    if(radio) radio.checked = (m===mode);
  });
}
function speak(level){
  if(voiceMode==='mute') return;
  const lang = voiceMode==='en' ? 'en' : 'th';
  const msg = VOICE_MSG[lang][level];
  if(!msg || !window.speechSynthesis) return;
  try{
    window.speechSynthesis.cancel();
    const u = new SpeechSynthesisUtterance(msg);
    u.lang = lang==='th' ? 'th-TH' : 'en-US';
    u.rate = 0.95;
    window.speechSynthesis.speak(u);
  }catch(e){}
}

let audioCtx=null;
function getAudioCtx(){ if(!audioCtx) audioCtx=new (window.AudioContext||window.webkitAudioContext)(); return audioCtx; }
function beep(freq,dur,vol,delay){
  try{
    const ctx=getAudioCtx(); const osc=ctx.createOscillator(); const gain=ctx.createGain();
    osc.connect(gain); gain.connect(ctx.destination); osc.frequency.value=freq; osc.type='sine';
    gain.gain.setValueAtTime(0,ctx.currentTime+delay);
    gain.gain.linearRampToValueAtTime(vol,ctx.currentTime+delay+.01);
    gain.gain.linearRampToValueAtTime(0,ctx.currentTime+delay+dur);
    osc.start(ctx.currentTime+delay); osc.stop(ctx.currentTime+delay+dur+.05);
  }catch(e){}
}
function playWarningBeep(){ beep(740,.16,.32,0); beep(740,.16,.32,.22); }
function playDangerBeep(){ beep(880,.18,.5,0); beep(1046,.18,.5,.22); beep(880,.18,.5,.44); }
document.addEventListener('touchstart',()=>{try{getAudioCtx();}catch(e){}},{once:true});
document.addEventListener('click',()=>{try{getAudioCtx();}catch(e){}},{once:true});

function openAlertModal(level, deficit){
  const lv = LEVELS.find(l=>l.key===level);
  const icon = document.getElementById('alert-modal-icon');
  const title = document.getElementById('alert-modal-title');
  const list = document.getElementById('alert-modal-list');
  const confirm = document.getElementById('alert-modal-confirm');
  const dv = document.getElementById('alert-modal-deficit');

  if(level==='WARNING'){
    icon.style.background='var(--amber-tint)'; icon.textContent='⚠'; icon.style.color='var(--amber)';
    title.textContent='WARNING'; title.style.color='var(--amber)';
    confirm.textContent='I Understand'; confirm.style.background='var(--amber)';
  } else {
    icon.style.background='var(--red-tint)'; icon.textContent='⛔'; icon.style.color='var(--red)';
    title.textContent='HARD STOP'; title.style.color='var(--red)';
    confirm.textContent='Confirm Hard Stop'; confirm.style.background='var(--red)';
  }
  dv.textContent = deficit.toLocaleString()+' mL';
  dv.style.color = lv.color;
  list.innerHTML = CLINICAL[level].map(t=>`<li>${t}</li>`).join('');
  document.getElementById('alert-modal-overlay').style.display='flex';
}
function closeAlertModal(){ document.getElementById('alert-modal-overlay').style.display='none'; }

function triggerSmartAlert(level, deficit){
  if(level===prevAlertLevel) return;
  prevAlertLevel = level;
  if(level==='WARNING'){ playWarningBeep(); speak('WARNING'); openAlertModal('WARNING', deficit); }
  else if(level==='DANGER'){ playDangerBeep(); speak('DANGER'); openAlertModal('DANGER', deficit); }
}

function startCase(){
  const hn = document.getElementById('f-hn').value.trim();
  if(!hn){ showModal('กรุณากรอก HN ก่อนเริ่มเคส', ()=>{}); return; }
  state.patient = {
    hn, name: document.getElementById('f-name').value,
    date: document.getElementById('f-date').value,
    surgeon: document.getElementById('f-surgeon').value,
    dx: document.getElementById('f-dx').value,
    operation: document.getElementById('f-operation').value,
    nurse: document.getElementById('f-nurse').value,
    mediaType: 'NSS',
  };
  state.started=true; state.startTime=new Date();
  state.mediaUsed=0; state.outputCollected=0; state.checkpoints=[];
  prevAlertLevel='SAFE';
  ['f-hn','f-name','f-date','f-surgeon','f-dx','f-operation','f-nurse'].forEach(id=>document.getElementById(id).disabled=true);
  const btn=document.getElementById('start-case-btn');
  btn.textContent='⟳ เริ่มเคสใหม่'; btn.onclick=confirmResetCase; btn.className='btn btn-ghost';
  document.getElementById('active-case').style.display='block';
  document.getElementById('topbar-timer').style.display='block';
  document.getElementById('sticky-deficit').style.display='flex';
  positionStickyBar();
  state.timerInterval=setInterval(updateTimer,30000);
  updateUI();
  window.scrollTo({top:document.getElementById('active-case').offsetTop-80, behavior:'smooth'});
}
function updateTimer(){
  if(!state.startTime) return;
  document.getElementById('elapsed-display').textContent = Math.round((new Date()-state.startTime)/60000)+' นาที';
}
function confirmEnd(){
  showModal('จบเคสและบันทึกลงประวัติ?', ()=>{ saveToHistory(); resetCase(); });
}
function confirmResetCase(){
  showModal('เริ่มเคสใหม่โดยไม่บันทึกเคสปัจจุบัน? ข้อมูลที่ยังไม่บันทึกจะหาย', resetCase);
}
function resetCase(){
  closeModal();
  clearInterval(state.timerInterval);
  state={started:false,startTime:null,mediaUsed:0,outputCollected:0,checkpoints:[],patient:{},timerInterval:null};
  prevAlertLevel='SAFE'; tapMediaVal=0; tapOutputVal=0;
  ['f-hn','f-name','f-date','f-surgeon','f-dx','f-operation','f-nurse'].forEach(id=>{
    const el=document.getElementById(id); el.disabled=false; el.value='';
  });
  document.getElementById('f-date').value=new Date().toISOString().slice(0,10);
  const btn=document.getElementById('start-case-btn');
  btn.textContent='🏥 เริ่มเคส Hysteroscopy'; btn.onclick=startCase; btn.className='btn btn-primary';
  document.getElementById('active-case').style.display='none';
  document.getElementById('topbar-timer').style.display='none';
  document.getElementById('sticky-deficit').style.display='none';
  document.getElementById('i-notes').value='';
  document.getElementById('cp-history').style.display='block';
  document.getElementById('cp-rows').innerHTML='<div id="cp-empty-state" style="text-align:center; color:var(--text2); font-size:12px; padding:14px; background:var(--card); border:1px solid var(--border); border-radius:10px; margin-bottom:7px">ยังไม่มีการบันทึก Checkpoint — กดปุ่มด้านบนเพื่อเริ่มบันทึกครั้งแรก</div>';
  document.getElementById('trend-card').style.display='none';
  updateTapDisplays();
  window.scrollTo({top:0, behavior:'smooth'});
}

function animateTap(btn){ if(!btn) return; btn.style.transform='scale(.93)'; setTimeout(()=>btn.style.transform='',120); }
function tapMedia(amt,btn){ tapMediaVal+=amt; animateTap(btn); updateTapPreview(); }
function tapOutput(amt,btn){ tapOutputVal+=amt; animateTap(btn); updateTapPreview(); }
function resetTap(){ tapMediaVal=0; tapOutputVal=0; updateTapPreview(); }
function updateTapDisplays(){
  document.getElementById('tap-media-display').textContent='0 mL';
  document.getElementById('tap-output-display').textContent='0 mL';
  document.getElementById('prev-media').textContent='0 mL';
  document.getElementById('prev-output').textContent='0 mL';
  const pd=document.getElementById('prev-deficit'); pd.textContent='— mL'; pd.style.color='var(--text2)';
  const cb=document.getElementById('confirm-btn'); cb.disabled=true; cb.style.opacity='.5';
}
function updateTapPreview(){
  document.getElementById('tap-media-display').textContent=tapMediaVal.toLocaleString()+' mL';
  document.getElementById('tap-output-display').textContent=tapOutputVal.toLocaleString()+' mL';
  document.getElementById('prev-media').textContent=tapMediaVal.toLocaleString()+' mL';
  document.getElementById('prev-output').textContent=tapOutputVal.toLocaleString()+' mL';
  const newDef=Math.max(0,(state.mediaUsed+tapMediaVal)-(state.outputCollected+tapOutputVal));
  const btn=document.getElementById('confirm-btn');
  const pd=document.getElementById('prev-deficit');
  if(tapMediaVal>0){
    const lv=getLevel(newDef);
    pd.textContent=newDef.toLocaleString()+' mL'; pd.style.color=lv.color;
    btn.disabled=false; btn.style.opacity='1';
    updateStickyDeficit(newDef, lv, true);
  } else {
    pd.textContent='— mL'; pd.style.color='var(--text2)';
    btn.disabled=true; btn.style.opacity='.5';
    updateStickyDeficit(Math.max(0,state.mediaUsed-state.outputCollected), getLevel(Math.max(0,state.mediaUsed-state.outputCollected)), false);
  }
}
function toggleManual(){
  isManualMode=!isManualMode;
  document.getElementById('tap-mode').style.display=isManualMode?'none':'block';
  document.getElementById('manual-mode').style.display=isManualMode?'block':'none';
  const b=document.getElementById('manual-toggle-btn');
  b.textContent=isManualMode?'⚡ One-Tap':'✏️ กรอกเอง';
}
function updatePreview(){
  const m=readMlInput('i-media');
  const o=readMlInput('i-output');
  if(Number.isNaN(m) || Number.isNaN(o)){
    document.getElementById('preview-box').style.display='block';
    document.getElementById('preview-box').textContent='กรุณากรอกตัวเลขจำนวนเต็มตั้งแต่ 0 ขึ้นไปเท่านั้น';
    return;
  }
  if(m>0){
    const newDef=Math.max(0,(state.mediaUsed+m)-(state.outputCollected+o));
    const lv=getLevel(newDef);
    document.getElementById('preview-box').style.display='block';
    document.getElementById('preview-box').innerHTML=`Deficit หลังบันทึก: <strong style="color:${lv.color}">${newDef.toLocaleString()} mL</strong>`;
    updateStickyDeficit(newDef, lv, true);
  } else {
    document.getElementById('preview-box').style.display='none';
    const def=Math.max(0,state.mediaUsed-state.outputCollected);
    updateStickyDeficit(def, getLevel(def), false);
  }
}

function addCheckpoint(){
  let m,o;
  if(isManualMode){ m=readMlInput('i-media'); o=readMlInput('i-output'); }
  else { m=tapMediaVal; o=tapOutputVal; }
  if(Number.isNaN(m) || Number.isNaN(o)){ showModal('กรุณากรอกตัวเลขจำนวนเต็มตั้งแต่ 0 ขึ้นไปเท่านั้น', ()=>{}); return; }
  if(m<=0){ showModal('กรุณาเลือก Media ที่ใช้ก่อน', ()=>{}); return; }

  const newMedia=state.mediaUsed+m, newOutput=state.outputCollected+o, newDef=newMedia-newOutput;
  const t=new Date(); const elapsed=Math.round((t-state.startTime)/60000);
  state.checkpoints.push({
    no:state.checkpoints.length+1,
    time:t.toLocaleTimeString('th-TH',{hour:'2-digit',minute:'2-digit'}),
    elapsed, addMedia:m, addOutput:o, cumMedia:newMedia, cumOutput:newOutput, deficit:newDef,
    level:getLevel(Math.max(0,newDef)).key,
  });
  state.mediaUsed=newMedia; state.outputCollected=newOutput;

  tapMediaVal=0; tapOutputVal=0; updateTapDisplays();
  try{ document.getElementById('i-media').value=''; document.getElementById('i-output').value=''; }catch(e){}
  try{ document.getElementById('preview-box').style.display='none'; }catch(e){}
  showCpFlash();
  updateUI();
}
function showCpFlash(){
  const el=document.getElementById('cp-flash');
  el.style.display='block'; el.style.opacity='1';
  setTimeout(()=>{ el.style.opacity='0'; setTimeout(()=>{el.style.display='none'; el.style.opacity='1';},300); },1700);
}

function updateUI(){
  const def=Math.max(0,state.mediaUsed-state.outputCollected);
  const lv=getLevel(def);

  const hero=document.getElementById('hero');
  hero.className = lv.key==='SAFE'?'state-safe':lv.key==='WARNING'?'state-warning':'state-danger';
  const badge=document.getElementById('hero-status-badge');
