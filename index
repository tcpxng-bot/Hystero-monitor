  const startStr=new Date(startTime).toLocaleTimeString('th-TH',{hour:'2-digit',minute:'2-digit'});
  const endStr=new Date(endTime).toLocaleTimeString('th-TH',{hour:'2-digit',minute:'2-digit'});
  const dur=Math.round((new Date(endTime)-new Date(startTime))/60000);
  const rows=checkpoints.map((cp,i)=>{
    const l=getLevel(Math.max(0,cp.deficit));
    return `<tr style="background:${i%2===0?'#fff':'#f5f7fa'}">
      <td style="text-align:center;background:#e8f1fb;font-weight:700;color:#1976D2;border:1px solid #d8e2eb">${cp.no}</td>
      <td style="text-align:center;border:1px solid #d8e2eb">${cp.time}</td><td style="text-align:center;border:1px solid #d8e2eb">${cp.elapsed}'</td>
      <td style="text-align:center;color:#1976D2;font-weight:600;border:1px solid #d8e2eb">+${cp.addMedia.toLocaleString()}</td>
      <td style="text-align:center;border:1px solid #d8e2eb">${cp.cumMedia.toLocaleString()}</td>
      <td style="text-align:center;color:#2E7D32;font-weight:600;border:1px solid #d8e2eb">+${cp.addOutput.toLocaleString()}</td>
      <td style="text-align:center;border:1px solid #d8e2eb">${cp.cumOutput.toLocaleString()}</td>
      <td style="text-align:center;font-weight:700;color:${l.hex};border:1px solid #d8e2eb">${cp.deficit.toLocaleString()}</td>
      <td style="text-align:center;font-weight:700;color:${l.hex};border:1px solid #d8e2eb">${l.key}</td><td style="border:1px solid #d8e2eb"></td></tr>`;
  }).join('');
  return `<div style="font-family:Arial,sans-serif;color:#111;background:#fff">
    <div style="background:#1976D2;color:#fff;padding:10px 16px;display:flex;justify-content:space-between;align-items:center;margin-bottom:10px">
      <div><div style="font-size:18px;font-weight:700">HYSTEROSCOPY FLUID DEFICIT MONITORING</div>
      <div style="font-size:9px;color:#cfe2f7;margin-top:2px">NSS Isotonic — AAGL/ESGE Guideline | Hard Stop 2,500 mL</div></div>
      <div style="text-align:right;font-size:9px;color:#cfe2f7"><div>พิมพ์: ${new Date().toLocaleDateString('th-TH',{year:'numeric',month:'long',day:'numeric'})}</div></div>
    </div>
    <div style="border:2px solid ${lv.hex};border-radius:8px;padding:12px 16px;margin-bottom:10px">
      <div style="display:flex;justify-content:space-between;gap:16px">
        <div style="flex:1;font-size:11px;line-height:1.9">
          <b>ผู้ป่วย:</b> ${safeP.name} | <b>HN:</b> ${safeP.hn}<br>
          <b>วันที่:</b> ${safeP.date} | <b>เวลา:</b> ${esc(startStr)}–${esc(endStr)} น. | <b>รวม:</b> ${dur} นาที<br>
          <b>แพทย์:</b> ${safeP.surgeon} | <b>พยาบาล:</b> ${safeP.nurse}<br>
          <b>Dx:</b> ${safeP.dx} | <b>Operation:</b> ${safeP.operation}<br>
          <b>Distension Media:</b> NSS | <b>Hard Stop:</b> 2,500 mL
        </div>
        <div style="text-align:center;min-width:130px;border-left:1px solid #ddd;padding-left:16px">
          <div style="font-size:9px;font-weight:700;color:#555">FINAL FLUID DEFICIT</div>
          <div style="font-size:32px;font-weight:900;color:${lv.hex}">${finalDeficit.toLocaleString()}</div>
          <div style="font-size:11px;color:#555">mL</div>
          <div style="margin-top:6px;background:${lv.hex};color:#fff;font-size:11px;font-weight:700;padding:3px 12px;border-radius:99px;display:inline-block">${lv.key}</div>
        </div>
      </div>
    </div>
    <table style="width:100%;border-collapse:collapse;margin-bottom:6px;font-size:8.5px">
      <thead><tr style="background:#1976D2;color:#fff"><th style="border:1px solid #d8e2eb;padding:5px">CP</th><th style="border:1px solid #d8e2eb;padding:5px">เวลา</th>
      <th style="border:1px solid #d8e2eb;padding:5px">นาที</th><th style="border:1px solid #d8e2eb;padding:5px">NSS</th><th style="border:1px solid #d8e2eb;padding:5px">ΣNSS</th>
      <th style="border:1px solid #d8e2eb;padding:5px">Output</th><th style="border:1px solid #d8e2eb;padding:5px">ΣOutput</th><th style="border:1px solid #d8e2eb;padding:5px">Deficit</th>
      <th style="border:1px solid #d8e2eb;padding:5px">Status</th><th style="border:1px solid #d8e2eb;padding:5px">หมายเหตุ</th></tr></thead>
      <tbody>${rows}</tbody></table>
    ${safeNotes?`<div style="background:#f5f7fa;border:1px solid #d8e2eb;border-radius:6px;padding:8px 12px;margin-bottom:10px;font-size:10px"><b>หมายเหตุ:</b> ${safeNotes}</div>`:''}
    <div style="display:flex;justify-content:space-between;font-size:9px;color:#444;margin-top:14px">
      <span>ลงชื่อพยาบาลบันทึก ..........................</span><span>วันที่ ......... เวลา ......... น.</span><span>แพทย์รับทราบ ..........................</span>
    </div>
  </div>`;
}
function printCase(){
  try{
    if(!state.startTime){ showModal('ยังไม่ได้เริ่มเคส ไม่สามารถพิมพ์รายงานได้', ()=>{}); return; }
    const notesEl = document.getElementById('i-notes');
    const html=printReportHTML(state.patient, state.checkpoints, state.mediaUsed, state.outputCollected,
      state.mediaUsed-state.outputCollected, notesEl?notesEl.value:'', state.startTime, new Date());
    document.getElementById('print-area').innerHTML=html;
    setTimeout(()=>{ window.print(); }, 80);
  }catch(e){
    showModal('เกิดข้อผิดพลาดขณะสร้างรายงาน: '+e.message, ()=>{});
  }
}
function printFromHistory(id){
  try{
    const all=getStoredCases();
    const c=all.find(x=>x.id===id);
    if(!c){ showModal('ไม่พบข้อมูลเคสนี้', ()=>{}); return; }
    const html=printReportHTML(c.patient, c.checkpoints, c.totalMedia, c.totalOutput, c.finalDeficit, c.notes, c.startTime, c.endTime);
    document.getElementById('print-area').innerHTML=html;
    setTimeout(()=>{ window.print(); }, 80);
  }catch(e){
    showModal('เกิดข้อผิดพลาดขณะสร้างรายงาน: '+e.message, ()=>{});
  }
}
</script>
