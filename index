function buildWorkbook(cases){
  const wb=XLSX.utils.book_new();
  const summaryHeader=['HN','ชื่อผู้ป่วย','วันที่','เวลาเริ่ม','แพทย์','พยาบาล','การวินิจฉัย','หัตถการ','Checkpoints','Total NSS (mL)','Total Output (mL)','Final Deficit (mL)','Status'];
  const summaryRows=cases.map(c=>[c.patient.hn,c.patient.name,c.patient.date,new Date(c.startTime).toLocaleTimeString('th-TH',{hour:'2-digit',minute:'2-digit'}),
    c.patient.surgeon,c.patient.nurse,c.patient.dx,c.patient.operation||'',c.checkpoints.length,c.totalMedia,c.totalOutput,c.finalDeficit,c.finalAlert]);
  const ws=XLSX.utils.aoa_to_sheet([summaryHeader,...summaryRows]);
  ws['!cols']=[{wch:12},{wch:20},{wch:12},{wch:10},{wch:16},{wch:16},{wch:20},{wch:24},{wch:12},{wch:14},{wch:14},{wch:14},{wch:10}];
  XLSX.utils.book_append_sheet(wb,ws,'สรุปทุกเคส');
  const byHN={};
  cases.forEach(c=>{ const k=c.patient.hn||'Unknown'; if(!byHN[k]) byHN[k]=[]; byHN[k].push(c); });
  Object.keys(byHN).forEach(hn=>{
    const rows=[['HN: '+hn],[],['CP','เวลา','นาที','HN','ชื่อ','วันที่','NSS','ΣNSS','Output','ΣOutput','Deficit','Status','หมายเหตุ']];
    byHN[hn].forEach(c=>{
      c.checkpoints.forEach(cp=>rows.push([cp.no,cp.time,cp.elapsed,c.patient.hn,c.patient.name,c.patient.date,cp.addMedia,cp.cumMedia,cp.addOutput,cp.cumOutput,cp.deficit,cp.level,c.notes||'']));
      rows.push([]);
    });
    const ws2=XLSX.utils.aoa_to_sheet(rows);
    XLSX.utils.book_append_sheet(wb,ws2,safeSheetName('HN_'+hn));
  });
  return wb;
}
