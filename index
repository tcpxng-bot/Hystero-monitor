<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Hysteroscopy Fluid Monitor</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Noto+Sans+Thai:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<style>
:root{
  --blue:#1976D2; --blue-dark:#125ea3; --blue-tint:#E8F1FB;
  --green:#2E7D32; --green-tint:#EAF5EA;
  --amber:#ED8F03; --amber-tint:#FEF3E0;
  --red:#C62828; --red-tint:#FBEAEA;
  --bg:#F4F7FA; --card:#FFFFFF; --text:#223042; --text2:#6B7B8C; --border:#D8E2EB;
  --radius:14px;
}
body.dark-theme{
  --bg:#16202C; --card:#1E2A38; --text:#E8EEF4; --text2:#94A7B8; --border:#2C3B4C;
  --blue-tint:#1B2E45; --green-tint:#1A2E1F; --amber-tint:#332512; --red-tint:#3A1A1A;
}
*{box-sizing:border-box;margin:0;padding:0}
body{
  font-family:'Inter','Noto Sans Thai',sans-serif;
  background:var(--bg); color:var(--text); min-height:100vh;
  -webkit-font-smoothing:antialiased; transition:background .25s,color .25s;
}
input,textarea,select{outline:none;font-family:inherit}
button{font-family:inherit;cursor:pointer;border:none;background:none}
button:active{transform:scale(.97)}
button:disabled{cursor:not-allowed}

#topbar{
  background:var(--card); border-bottom:1px solid var(--border);
  padding:14px 16px; display:flex; align-items:center; justify-content:space-between; gap:10px;
  position:sticky; top:0; z-index:100;
}
@media (max-width:380px){
  #topbar{padding:12px 10px; gap:6px}
  #topbar-right{gap:5px}
  .btn{padding:8px 11px; font-size:11.5px}
  .icon-btn{width:32px; height:32px}
}
#topbar .logo{display:flex; align-items:center; gap:11px; min-width:0; flex:1}
#topbar .logo-icon{
  width:38px; height:38px; border-radius:10px; background:var(--blue);
  display:flex; align-items:center; justify-content:center; font-size:18px; color:#fff; flex-shrink:0;
}
#topbar .title{font-size:15px; font-weight:700; color:var(--text); letter-spacing:-.01em; white-space:nowrap; overflow:hidden; text-overflow:ellipsis}
#topbar .subtitle{font-size:10.5px; color:var(--text2); margin-top:1px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis}
#topbar-right{display:flex; gap:8px; align-items:center; flex-shrink:0}
.icon-btn{
  width:34px; height:34px; border-radius:9px; background:var(--bg); border:1px solid var(--border);
  display:flex; align-items:center; justify-content:center; font-size:15px; color:var(--text2);
  transition:.15s;
}
.icon-btn:hover{background:var(--border)}
.btn{border-radius:10px; padding:9px 16px; font-size:12.5px; font-weight:700; transition:.15s; letter-spacing:-.01em; white-space:nowrap; flex-shrink:0}
.btn-primary{background:var(--blue); color:#fff}
.btn-primary:hover{background:var(--blue-dark)}
.btn-ghost{background:var(--bg); border:1px solid var(--border); color:var(--text2)}
.btn-ghost:hover{background:var(--border)}
.btn-green{background:var(--green); color:#fff}
.btn-danger-outline{background:var(--red-tint); color:var(--red); border:1px solid var(--red)}
#topbar-timer{
  background:var(--blue-tint); border:1px solid var(--blue); border-radius:9px;
  padding:5px 12px; font-size:11px; text-align:right; color:var(--blue-dark);
}
#topbar-timer b{font-size:13px}

#sticky-deficit{
  display:none; position:sticky; top:0; z-index:95;
  background:var(--card); border-bottom:2px solid var(--border);
  padding:10px 14px; align-items:center; justify-content:center; gap:8px;
  box-shadow:0 2px 6px rgba(20,40,60,.05);
  white-space:nowrap; overflow-x:auto; -webkit-overflow-scrolling:touch;
}
#sticky-deficit::-webkit-scrollbar{display:none}
#sticky-deficit .sd-dot{width:8px; height:8px; border-radius:50%; flex-shrink:0}
#sticky-deficit .sd-label{font-size:9.5px; color:var(--text2); font-weight:700; letter-spacing:.03em; text-transform:uppercase; flex-shrink:0}
#sticky-deficit .sd-value{font-size:16px; font-weight:900; flex-shrink:0}
#sticky-deficit .sd-sep{color:var(--border); font-size:13px; flex-shrink:0}
#sticky-deficit .sd-remain{font-size:10.5px; color:var(--text2); font-weight:600; flex-shrink:0}

#main{max-width:720px; margin:0 auto; padding:18px 16px 40px}
.card{
  background:var(--card); border:1px solid var(--border); border-radius:var(--radius);
  padding:18px 20px; margin-bottom:14px; box-shadow:0 1px 2px rgba(20,40,60,.04);
}
.card-title{font-size:11px; color:var(--text2); font-weight:700; letter-spacing:.06em; margin-bottom:12px; text-transform:uppercase}
.field-label{font-size:12px; color:var(--text2); margin-bottom:5px; font-weight:500}
.field-input{
  width:100%; background:var(--bg); border:1px solid var(--border); border-radius:9px;
  color:var(--text); padding:10px 12px; font-size:13.5px; transition:.15s;
}
.field-input:focus{border-color:var(--blue); background:var(--card)}
.field-input:disabled{background:var(--border); color:var(--text2)}
.grid2{display:grid; grid-template-columns:1fr 1fr; gap:12px}

.tabs{display:flex; gap:6px; margin-bottom:16px}
.tab{
  padding:9px 18px; border-radius:9px; font-size:13px; font-weight:600;
  background:var(--card); color:var(--text2); border:1px solid var(--border); transition:.15s;
}
.tab.active{background:var(--blue); color:#fff; border-color:var(--blue)}

#hero{
  border-radius:18px; padding:24px 24px 20px; margin-bottom:14px;
  background:var(--card); border:1.5px solid var(--border); position:relative; overflow:hidden;
  transition:border-color .3s, box-shadow .3s;
}
#hero.state-safe{border-color:var(--green)}
#hero.state-warning{border-color:var(--amber); animation:pulse-amber 2.2s ease-in-out infinite}
#hero.state-danger{border-color:var(--red); animation:pulse-red 1.4s ease-in-out infinite}
@keyframes pulse-amber{0%,100%{box-shadow:0 0 0 0 rgba(237,143,3,.18)}50%{box-shadow:0 0 0 8px rgba(237,143,3,0)}}
@keyframes pulse-red{0%,100%{box-shadow:0 0 0 0 rgba(198,40,40,.22)}50%{box-shadow:0 0 0 10px rgba(198,40,40,0)}}
#hero-eyebrow{font-size:11px; font-weight:700; letter-spacing:.08em; color:var(--text2); text-transform:uppercase; margin-bottom:6px}
#hero-status-badge{
  display:inline-flex; align-items:center; gap:6px; font-size:12px; font-weight:800;
  padding:5px 14px; border-radius:99px; letter-spacing:.03em; margin-bottom:14px;
}
#hero-value{font-size:56px; font-weight:900; line-height:1; letter-spacing:-.02em}
#hero-value span{font-size:18px; font-weight:700; margin-left:4px}
#hero-grid{display:grid; grid-template-columns:1fr auto; gap:20px; align-items:flex-end; margin-top:6px}
#hero-remaining{text-align:right}
#hero-remaining .lbl{font-size:10.5px; color:var(--text2); font-weight:600; margin-bottom:2px}
#hero-remaining .val{font-size:26px; font-weight:800; line-height:1}
#hero-remaining .unit{font-size:11px; color:var(--text2)}
#hero-gauge-wrap{margin-top:18px}
#hero-gauge-labels{display:flex; justify-content:space-between; font-size:10.5px; color:var(--text2); margin-bottom:6px; font-weight:500}
#hero-gauge-track{height:10px; background:var(--bg); border-radius:99px; overflow:hidden; border:1px solid var(--border)}
#hero-gauge-fill{height:100%; border-radius:99px; transition:width .5s cubic-bezier(.4,0,.2,1), background .3s}
#hero-footer{display:flex; gap:8px; margin-top:16px; flex-wrap:wrap}
.hero-chip{
  font-size:11px; font-weight:600; color:var(--text2); background:var(--bg);
  border:1px solid var(--border); border-radius:99px; padding:5px 12px; display:flex; align-items:center; gap:6px;
}

#clinical-panel{border-radius:var(--radius); padding:16px 20px; margin-bottom:14px; border:1px solid var(--border)}
#clinical-panel .cp-title{font-size:11px; font-weight:700; letter-spacing:.05em; text-transform:uppercase; margin-bottom:10px}
#clinical-panel ul{list-style:none; display:flex; flex-direction:column; gap:7px}
#clinical-panel li{font-size:13px; line-height:1.5; display:flex; gap:8px}

.stats{display:grid; grid-template-columns:1fr 1fr 1fr; gap:10px; margin-bottom:14px}
.stat{background:var(--card); border:1px solid var(--border); border-radius:12px; padding:13px 10px; text-align:center}
.stat-label{font-size:9.5px; color:var(--text2); font-weight:700; letter-spacing:.05em; margin-bottom:5px; text-transform:uppercase}
.stat-value{font-size:19px; font-weight:800}
.stat-unit{font-size:10px; color:var(--text2)}

.progress-box{background:var(--card); border:1px solid var(--border); border-radius:12px; padding:12px 16px; margin-bottom:14px}
.progress-row{display:flex; justify-content:space-between; margin-bottom:6px; font-size:11.5px; font-weight:600; color:var(--text2)}
.progress-track{height:7px; background:var(--bg); border-radius:99px; overflow:hidden; border:1px solid var(--border)}
.progress-fill{height:100%; border-radius:99px; background:var(--blue); transition:width .4s}

.tap-section-label{font-size:11px; font-weight:700; letter-spacing:.04em; margin-bottom:8px; display:flex; justify-content:space-between; align-items:center; text-transform:uppercase}
.tap-grid{display:grid; grid-template-columns:1fr 1fr 1fr; gap:8px; margin-bottom:14px}
.tap-btn{
  border-radius:11px; padding:14px 0; font-size:15px; font-weight:800;
  border:1.5px solid var(--border); background:var(--bg); color:var(--text); transition:.15s;
}
.tap-btn:active{transform:scale(.95); filter:brightness(.97)}
.tap-btn.intake{border-color:#bcd6f0; color:var(--blue)}
.tap-btn.intake.lg{background:var(--blue-tint); border-color:var(--blue)}
.tap-btn.output{border-color:#b6dcc0; color:var(--green)}
.tap-btn.output.lg{background:var(--green-tint); border-color:var(--green)}
#tap-preview{
  background:var(--bg); border:1px solid var(--border); border-radius:11px;
  padding:13px 16px; margin-bottom:12px;
}
.tap-preview-row{display:flex; justify-content:space-between; font-size:10.5px; color:var(--text2); margin-bottom:6px; font-weight:600}
.tap-preview-values{display:flex; justify-content:space-between; align-items:center; font-size:16px; font-weight:800}

.cp-row{
  display:flex; align-items:center; gap:12px; padding:11px 14px; border-radius:10px;
  border:1px solid var(--border); margin-bottom:7px; background:var(--card); transition:.15s;
}
.cp-row.latest{border-color:var(--blue); background:var(--blue-tint)}
.cp-row .cp-num{
  width:34px; height:34px; border-radius:8px; background:var(--bg); display:flex; flex-direction:column; align-items:center;
  justify-content:center; font-size:11.5px; font-weight:800; color:var(--text2); flex-shrink:0; line-height:1.1;
}
.cp-row.latest .cp-num{background:var(--blue); color:#fff}
.cp-badge{font-size:10px; font-weight:800; padding:3px 9px; border-radius:99px; letter-spacing:.02em}

#alert-modal-overlay{
  display:none; position:fixed; inset:0; z-index:9999; background:rgba(10,16,24,.72);
  align-items:center; justify-content:center; padding:20px; backdrop-filter:blur(2px);
}
#alert-modal{
  background:var(--card); border-radius:20px; max-width:380px; width:100%; padding:30px 26px 24px;
  text-align:center; box-shadow:0 20px 60px rgba(0,0,0,.3);
}
#alert-modal-icon{width:74px; height:74px; border-radius:50%; margin:0 auto 14px; display:flex; align-items:center; justify-content:center; font-size:34px}
#alert-modal-title{font-size:20px; font-weight:900; letter-spacing:.02em; margin-bottom:14px}
#alert-modal-deficit-lbl{font-size:11px; color:var(--text2); font-weight:600; margin-bottom:2px}
#alert-modal-deficit{font-size:38px; font-weight:900; margin-bottom:16px}
#alert-modal-actions{text-align:left; background:var(--bg); border-radius:12px; padding:14px 16px; margin-bottom:18px}
#alert-modal-actions .lbl{font-size:10.5px; font-weight:700; color:var(--text2); letter-spacing:.04em; margin-bottom:8px; text-transform:uppercase}
#alert-modal-actions ul{list-style:none; display:flex; flex-direction:column; gap:6px}
#alert-modal-actions li{font-size:12.5px; line-height:1.4; display:flex; gap:7px}
#alert-modal-confirm{width:100%; padding:14px; border-radius:11px; font-size:14.5px; font-weight:800; color:#fff}

.modal-overlay{display:none; position:fixed; inset:0; background:rgba(10,16,24,.55); z-index:9000; align-items:center; justify-content:center; padding:20px}
.modal-box{background:var(--card); border-radius:16px; max-width:380px; width:100%; padding:22px 20px}
.radio-row{display:flex; align-items:center; gap:8px; padding:9px 12px; border-radius:9px; border:1px solid var(--border); margin-bottom:7px; cursor:pointer}
.radio-row.checked{border-color:var(--blue); background:var(--blue-tint)}

#sync-indicator{display:none; position:fixed; bottom:18px; right:18px; z-index:500; background:var(--card); border:1px solid var(--border); border-radius:10px; padding:9px 15px; font-size:11.5px; color:var(--text2); box-shadow:0 4px 14px rgba(0,0,0,.08)}
#cp-flash{display:none; position:fixed; top:74px; left:50%; transform:translateX(-50%); z-index:300; background:var(--green); color:#fff; font-size:13.5px; font-weight:700; padding:10px 22px; border-radius:99px; box-shadow:0 6px 18px rgba(46,125,50,.3); transition:opacity .3s}

.case-row{background:var(--card); border:1px solid var(--border); border-radius:11px; padding:12px 16px; margin-bottom:8px; display:flex; align-items:center; justify-content:space-between; font-size:13px}
.case-row .name{font-weight:700; color:var(--text); font-size:13.5px}
.case-row .meta{color:var(--text2); font-size:11px; margin-top:2px}

@media print{
  #topbar,#tabs,.tab,#input-section,.btn-print,.btn-excel,.no-print,#alert-modal-overlay,#sync-indicator,#cp-flash,#sticky-deficit,#screen-flash,.modal-overlay,#main>*{display:none!important}
  body{background:#fff!important; color:#111}
  #print-area{display:block!important; margin:0; padding:0}
  @page{size:A4 portrait; margin:10mm 13mm}
}
#print-area{display:none}
#screen-flash{display:none}

::placeholder{color:#A7B6C4}
</style>
</head>
<body>

<div id="topbar">
  <div class="logo">
    <div class="logo-icon">💧</div>
    <div>
      <div class="title">Hysteroscopy Fluid Monitor</div>
      <div class="subtitle">Fluid Deficit Monitoring System</div>
    </div>
  </div>
  <div id="topbar-right">
    <button class="icon-btn" id="theme-toggle-btn" onclick="toggleTheme()" title="สลับธีม">🌙</button>
    <button class="btn btn-ghost" onclick="openSettings()">⚙ ตั้งค่า</button>
    <div id="topbar-timer" style="display:none">
      <div style="font-size:9px">ระยะเวลา</div>
      <b id="elapsed-display">0 นาที</b>
    </div>
  </div>
</div>

<div id="sticky-deficit">
  <span class="sd-dot" id="sd-dot"></span>
  <span class="sd-label">DEFICIT</span>
  <span class="sd-value" id="sd-value">0 mL</span>
  <span class="sd-sep">|</span>
  <span class="sd-remain">เหลือ <b id="sd-remain">2,500</b> mL ก่อน Hard Stop</span>
</div>

<div id="main">

  <div class="tabs" id="tabs">
    <div class="tab active" onclick="showTab('record')">📋 บันทึกเคส</div>
    <div class="tab" onclick="showTab('history')">📁 ประวัติเคส</div>
  </div>

  <div id="tab-record">

    <div class="card" id="patient-card">
      <div class="card-title">ข้อมูลผู้ป่วย</div>
      <div class="grid2">
        <div><div class="field-label">HN / รหัสผู้ป่วย</div><input class="field-input" id="f-hn" placeholder="รหัสผู้ป่วย"></div>
        <div><div class="field-label">ชื่อ-นามสกุล</div><input class="field-input" id="f-name" placeholder="ชื่อผู้ป่วย"></div>
        <div><div class="field-label">วันที่ผ่าตัด</div><input class="field-input" id="f-date" type="date"></div>
        <div><div class="field-label">แพทย์ผ่าตัด</div><input class="field-input" id="f-surgeon" placeholder="ชื่อแพทย์"></div>
        <div><div class="field-label">การวินิจฉัย (Diagnosis)</div><input class="field-input" id="f-dx" placeholder="เช่น Myoma uteri, AUB"></div>
        <div><div class="field-label">หัตถการ (Operation)</div><input class="field-input" id="f-operation" placeholder="เช่น Hysteroscopic myomectomy"></div>
        <div style="grid-column:1/-1"><div class="field-label">พยาบาลผู้บันทึก</div><input class="field-input" id="f-nurse" placeholder="ชื่อพยาบาล"></div>
        <div style="grid-column:1/-1">
          <div style="background:var(--blue-tint); border:1px solid var(--blue); border-radius:9px; padding:9px 12px; display:flex; align-items:center; gap:8px">
            <span style="font-size:15px">💧</span>
            <span style="font-size:12px; color:var(--blue-dark); font-weight:700">Distension Media: NSS (Isotonic)</span>
            <span style="font-size:10.5px; color:var(--text2); margin-left:auto">Hard Stop 2,500 mL</span>
          </div>
        </div>
      </div>
      <button class="btn btn-primary" id="start-case-btn" style="width:100%; margin-top:14px; padding:13px; font-size:14.5px" onclick="startCase()">🏥 เริ่มเคส Hysteroscopy</button>
    </div>

    <div id="active-case" style="display:none">

      <div id="hero" class="state-safe">
        <div id="hero-eyebrow">CURRENT FLUID DEFICIT</div>
        <div id="hero-status-badge">● SAFE</div>
        <div id="hero-grid">
          <div>
            <div id="hero-value">0<span>mL</span></div>
          </div>
          <div id="hero-remaining">
            <div class="lbl">REMAINING BEFORE HARD STOP</div>
            <div class="val" id="hero-remaining-val">2,500</div>
            <div class="unit">mL</div>
          </div>
        </div>
        <div id="hero-gauge-wrap">
          <div id="hero-gauge-labels"><span>0</span><span id="hero-gauge-pct">0%</span><span>2,500 mL (Hard Stop)</span></div>
          <div id="hero-gauge-track"><div id="hero-gauge-fill" style="width:0%"></div></div>
        </div>
        <div id="hero-footer">
          <div class="hero-chip">💧 NSS Isotonic</div>
          <div class="hero-chip">⛔ Hard Stop 2,500 mL</div>
          <div class="hero-chip" id="hero-desc-chip">✓ อยู่ในเกณฑ์ปกติ</div>
        </div>
      </div>

      <div id="clinical-panel">
        <div class="cp-title" id="cp-title">CLINICAL RECOMMENDATION — SAFE</div>
        <ul id="cp-list"></ul>
      </div>

      <div class="stats">
        <div class="stat"><div class="stat-label">Intake</div><div class="stat-value" id="s-intake" style="color:var(--blue)">0</div><div class="stat-unit">mL</div></div>
        <div class="stat"><div class="stat-label">Output</div><div class="stat-value" id="s-output" style="color:var(--green)">0</div><div class="stat-unit">mL</div></div>
        <div class="stat"><div class="stat-label">Next CP</div><div class="stat-value" id="s-next" style="color:var(--amber)">+2,000</div><div class="stat-unit">mL</div></div>
      </div>

      <div class="progress-box">
        <div class="progress-row"><span id="progress-label">Progress to CP1 (0 / 2,000 mL)</span><span id="progress-pct">0%</span></div>
        <div class="progress-track"><div class="progress-fill" id="progress-bar" style="width:0%"></div></div>
      </div>

      <div class="card" id="trend-card" style="display:none">
        <div class="card-title">Deficit Trend</div>
        <div id="trend-graph" style="display:flex; align-items:flex-end; gap:5px; height:56px"></div>
        <div style="display:flex; justify-content:space-between; margin-top:5px; font-size:10px; color:var(--text2)">
          <span>CP1</span><span id="trend-last-label"></span>
        </div>
      </div>

      <div class="card" id="input-section">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:14px">
          <div>
            <div class="card-title" style="margin-bottom:0">Checkpoint #<span id="cp-no">1</span></div>
            <div id="cp-target-hint" style="font-size:10.5px; color:var(--text2); margin-top:2px">เป้าหมายสะสม: <b id="cp-target-val" style="color:var(--blue)">2,000</b> mL</div>
          </div>
          <button class="btn btn-ghost" id="manual-toggle-btn" style="padding:5px 11px; font-size:11px" onclick="toggleManual()">✏️ กรอกเอง</button>
        </div>

        <div id="tap-mode">
          <div class="tap-section-label" style="color:var(--blue)"><span>💧 INTAKE (NSS)</span><span id="tap-media-display">0 mL</span></div>
          <div class="tap-grid">
            <button class="tap-btn intake" onclick="tapMedia(100,this)">+100</button>
            <button class="tap-btn intake" onclick="tapMedia(500,this)">+500</button>
            <button class="tap-btn intake lg" onclick="tapMedia(1000,this)">+1,000</button>
          </div>
          <div class="tap-section-label" style="color:var(--green)"><span>🪣 OUTPUT</span><span id="tap-output-display">0 mL</span></div>
