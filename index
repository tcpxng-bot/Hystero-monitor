        <div style="font-size:10.5px; color:var(--text2)">${cp.time} น. · ${cp.elapsed}' · Σ ${cp.cumMedia.toLocaleString()}/${cp.cumOutput.toLocaleString()} mL</div>
      </div>
      <div style="text-align:right">
        <div style="font-weight:800; font-size:14px; color:${l.color}">${cp.deficit.toLocaleString()}</div>
        <span class="cp-badge" style="color:${l.color}; background:${l.tint}">${l.key}</span>
      </div>`;
    rows.appendChild(row);
  });
  document.getElementById('cp-count').textContent=state.checkpoints.length+' รายการ';

  triggerSmartAlert(lv.key, def);
